{
	"include": ["**/*.ts", "**/*.tsx"],
	// scripts/ holds one-off bun runtime scripts (bun:sqlite, etc.), executed
	// with `bun`, not part of the published library surface.
	"exclude": ["scripts"],
	"compilerOptions": {
		"target": "ES2022",
		"module": "ESNext",
		"lib": ["ES2022", "DOM", "DOM.Iterable"],
		"types": ["node"],
		"moduleResolution": "bundler",
		"allowImportingTsExtensions": true,
		"verbatimModuleSyntax": true,
		"noEmit": true,
		"skipLibCheck": true,
		"strict": true,
		"noFallthroughCasesInSwitch": true,
		"noUncheckedSideEffectImports": true,
		"plugins": [
			{
				"name": "@effect/language-service",
				"reportSuggestionsAsWarningsInTsc": true
			}
		]
	}
}
