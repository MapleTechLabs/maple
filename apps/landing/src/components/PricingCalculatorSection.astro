---
import { PricingCalculator } from "./PricingCalculator";

interface Props {
    competitor: "datadog" | "grafana" | "new-relic" | "dash0";
    competitorName: string;
}

const { competitor, competitorName } = Astro.props;
---

<section class="py-24 md:py-32">
    <div class="mx-auto max-w-5xl px-6">
        <div class="mb-10">
            <span class="inline-flex items-center rounded-full border border-border bg-card px-2.5 py-0.5 text-[10px] font-medium uppercase tracking-wider text-accent mb-4">
                Pricing
            </span>
            <h2 class="font-display text-2xl sm:text-3xl font-bold text-fg tracking-tight">
                Estimated monthly cost: Maple vs {competitorName}
            </h2>
            <p class="mt-2 text-sm text-fg-muted max-w-2xl">
                Drag the sliders to match your usage and see how the costs compare.
            </p>
        </div>

        <PricingCalculator competitor={competitor} client:visible />
    </div>
</section>

<style is:global>
    .slider-input::-webkit-slider-thumb {
        -webkit-appearance: none;
        appearance: none;
        width: 14px;
        height: 14px;
        border-radius: 9999px;
        background: oklch(0.75 0.12 70);
        cursor: pointer;
        position: relative;
        z-index: 2;
    }
    .slider-input::-moz-range-thumb {
        width: 14px;
        height: 14px;
        border-radius: 9999px;
        border: none;
        background: oklch(0.75 0.12 70);
        cursor: pointer;
        position: relative;
        z-index: 2;
    }
    .slider-input::-webkit-slider-thumb:hover {
        background: oklch(0.8 0.14 70);
    }
    .slider-input::-moz-range-thumb:hover {
        background: oklch(0.8 0.14 70);
    }
    .slider-input:focus {
        outline: none;
    }
</style>
