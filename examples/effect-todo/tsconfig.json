{
	"include": ["shared/**/*.ts", "server/**/*.ts"],
	"compilerOptions": {
		"target": "ES2023",
		"module": "ESNext",
		"lib": ["ES2023"],
		"types": ["bun", "node"],
		"moduleResolution": "bundler",
		"allowImportingTsExtensions": true,
		"verbatimModuleSyntax": false,
		"noEmit": true,
		"skipLibCheck": true,
		"strict": true,
		"exactOptionalPropertyTypes": false
	}
}
