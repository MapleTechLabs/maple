---
import PixelIcon from "./PixelIcon.astro";
import type { PixelIconName } from "./pixel-icons";

interface Props {
    class?: string;
}

const { class: className = "" } = Astro.props;

type Placement = { name: PixelIconName; top: number; left: number; size: number; opacity: number };

// Hand-tuned scatter — a loose telemetry "constellation". Top-right is kept clear
// for the focal glyph; bottom-left is kept light for the terminal prompt.
const FIELD: Placement[] = [
    { name: "trend", top: 14, left: 8, size: 30, opacity: 0.11 },
    { name: "gauge", top: 10, left: 32, size: 22, opacity: 0.08 },
    { name: "layers", top: 20, left: 54, size: 24, opacity: 0.08 },
    { name: "bars", top: 40, left: 13, size: 26, opacity: 0.1 },
    { name: "window", top: 46, left: 37, size: 30, opacity: 0.09 },
    { name: "box", top: 36, left: 62, size: 22, opacity: 0.08 },
    { name: "stack", top: 66, left: 22, size: 26, opacity: 0.09 },
    { name: "grid", top: 70, left: 47, size: 22, opacity: 0.08 },
    { name: "cloud", top: 60, left: 70, size: 26, opacity: 0.1 },
    { name: "eye", top: 82, left: 58, size: 20, opacity: 0.08 },
];
---

<div class:list={["pointer-events-none absolute inset-0 overflow-hidden", className]} aria-hidden="true">
    {FIELD.map((p) => (
        <span
            class="absolute"
            style={`top:${p.top}%;left:${p.left}%;width:${p.size}px;height:${p.size}px;opacity:${p.opacity}`}
        >
            <PixelIcon name={p.name} class="h-full w-full" />
        </span>
    ))}
</div>
