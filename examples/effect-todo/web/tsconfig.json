{
	"include": ["src/**/*.ts", "src/**/*.tsx", "../shared/**/*.ts", "vite.config.ts"],
	"compilerOptions": {
		"target": "ES2023",
		"jsx": "react-jsx",
		"module": "ESNext",
		"lib": ["ES2023", "DOM", "DOM.Iterable"],
		"types": ["vite/client", "node"],
		"moduleResolution": "bundler",
		"allowImportingTsExtensions": true,
		"verbatimModuleSyntax": false,
		"noEmit": true,
		"skipLibCheck": true,
		"strict": true
	}
}
