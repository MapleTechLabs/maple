{
  "name": "@maple/agents",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "portless": { "name": "agents", "script": "dev:app" },
  "scripts": {
    "dev": "portless",
    "dev:app": "tsx watch src/server/index.ts",
    "dev:ui": "vite",
    "start": "tsx src/server/index.ts",
    "build": "vite build",
    "infra": "docker compose up -d",
    "infra:down": "docker compose down",
    "infra:logs": "docker compose logs -f electric-agents",
    "agents": "electric-agents",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@durable-streams/state": "npm:@electric-ax/durable-streams-state-beta@^0.3.1",
    "@electric-ax/agents": "^0.4.8",
    "@electric-ax/agents-runtime": "^0.3.4",
    "@mariozechner/pi-agent-core": "^0.70.6",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@sinclair/typebox": "^0.34.49",
    "@tanstack/db": "^0.6.7",
    "@tanstack/react-db": "^0.1.85",
    "react": "catalog:react",
    "react-dom": "catalog:react",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "catalog:tooling",
    "@types/react": "catalog:react",
    "@types/react-dom": "catalog:react",
    "@vitejs/plugin-react": "^6.0.2",
    "tsx": "^4.22.3",
    "typescript": "catalog:tooling",
    "vite": "catalog:"
  }
}
