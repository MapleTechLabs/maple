# --- LLM (routed through OpenRouter, same provider Maple uses) ---
# An OpenRouter API key. Re-use the key Maple uses for its chat agent.
OPENROUTER_API_KEY=

# --- Electric Agents server (from docker compose) ---
# Where the agents-server is reachable from this Node process.
# (docker-compose publishes the agents-server on host port 4438.)
AGENTS_URL=http://localhost:4438

# --- This app (long-lived webhook + REST server) ---
PORT=4700
# URL the agents-server (in Docker) uses to deliver wakes back to this app's
# /webhook. It must be reachable from inside the container, so use
# host.docker.internal rather than localhost.
SERVE_URL=http://host.docker.internal:4700
