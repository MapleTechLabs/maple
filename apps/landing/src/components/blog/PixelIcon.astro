---
import { PIXEL_ICONS, type PixelIconName } from "./pixel-icons";

interface Props {
    name: PixelIconName;
    class?: string;
}

const { name, class: className = "" } = Astro.props;
---

<svg
    viewBox="0 0 24 24"
    fill="none"
    class={className}
    aria-hidden="true"
    set:html={PIXEL_ICONS[name]}
></svg>
