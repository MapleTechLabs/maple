{
	"name": "@maple/chat-agent",
	"private": true,
	"type": "module",
	"portless": { "name": "chat-agent", "script": "dev:app" },
	"scripts": {
		"dev": "portless",
		"dev:app": "bun run ../../scripts/portless-wrangler.ts --env-file ../../.env.local --port ${PORT:-8787} --inspector-port=9230",
		"dev:no-portless": "PORT=8787 bun run dev:app",
		"typecheck": "tsc --noEmit"
	},
	"dependencies": {
		"@ai-sdk/openai-compatible": "^2.0.30",
		"@clerk/backend": "^2.30.1",
		"@cloudflare/ai-chat": "^0.3.2",
		"@maple/agent-harness": "workspace:*",
		"@maple/api": "workspace:*",
		"agents": "^0.9.0",
		"ai": "^6.0.146",
		"effect": "catalog:effect",
		"zod": "^4.3.6"
	},
	"devDependencies": {
		"@cloudflare/workers-types": "^4.20250214.0",
		"alchemy": "^0.91.2",
		"typescript": "catalog:tooling",
		"wrangler": "^4.14.4"
	}
}
